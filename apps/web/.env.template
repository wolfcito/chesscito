# RainbowKit Wallet Configuration
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_project_id_here

# Server-authoritative signing
SIGNER_PRIVATE_KEY=

# Active chain for the live demo
NEXT_PUBLIC_CHAIN_ID=42220
NEXT_PUBLIC_SCOREBOARD_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_BADGES_ADDRESS=0x0000000000000000000000000000000000000000

# MiniPay fee currency override
NEXT_PUBLIC_MINIPAY_FEE_CURRENCY=

# Optional: set to 0 to hide raw tx debug tools in MiniPay
NEXT_PUBLIC_ENABLE_MINIPAY_RAWTX=1

# Optional: set to 1 to enable QA tools in play-hub (levelId override)
NEXT_PUBLIC_QA_MODE=0

# Optional: private RPC for leaderboard indexing (defaults to forno.celo.org)
CELO_RPC_URL=

# Shop economy (USDC payments)
NEXT_PUBLIC_SHOP_ADDRESS=0x0000000000000000000000000000000000000000
NEXT_PUBLIC_USDC_ADDRESS=0x0000000000000000000000000000000000000000

# Gitcoin Passport gating (server-side only)
PASSPORT_API_KEY=
PASSPORT_SCORER_ID=
