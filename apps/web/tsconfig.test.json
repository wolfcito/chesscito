{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "module": "nodenext",
    "moduleResolution": "nodenext",
    "target": "es2020",
    "outDir": ".tmp/game-tests",
    "rootDir": "src",
    "noEmit": false
  },
  "include": [
    "src/lib/game/types.ts",
    "src/lib/game/board.ts",
    "src/lib/game/rules/**/*.ts",
    "src/lib/game/__tests__/**/*.ts"
  ],
  "exclude": []
}
